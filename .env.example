# Copy to .env.local for local development.
# Base URL of the pricing-optimizer-api backend.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Sentry DSN (issue #19). Safe to expose client-side by design — it's not a
# secret, just a submit-only endpoint identifier (see Sentry's own docs).
# Leave unset to run with error reporting off (see instrumentation-client.ts).
NEXT_PUBLIC_SENTRY_DSN=
