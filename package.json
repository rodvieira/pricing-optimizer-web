{
  "name": "pricing-optimizer-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "build:theme": "astryx theme build src/shared/theme/pricing-optimizer-theme.ts -o src/shared/theme/generated/pricing-optimizer.css",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lighthouse": "mkdir -p .lighthouse && node scripts/lighthouse.mjs",
    "sync-openapi": "cp ../openapi.yaml ./openapi.yaml && pnpm run codegen",
    "codegen": "openapi-typescript openapi.yaml -o src/shared/api/schema.ts",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.6",
    "@astryxdesign/theme-neutral": "^0.1.6",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "^10.67.0",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.6",
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "chrome-launcher": "^1.2.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "lighthouse": "^13.4.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
